{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${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}"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/pre-write-check.sh"}]
      },
      {
        "matcher": "Edit",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/pre-write-check.sh"}]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/post-format.sh"}]
      },
      {
        "matcher": "Edit",
        "hooks": [{"type": "command", "command": "bash .claude/hooks/post-format.sh"}]
      }
    ]
  }
}
